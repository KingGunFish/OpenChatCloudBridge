{
  "name": "openclaw-cloud-bridge-lite",
  "version": "2.0.0",
  "description": "OpenClaw Cloud Bridge Hub - Lite version for low-memory servers",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "cloud-bridge": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "setup": "tsx src/cli.ts setup",
    "verify": "tsx src/cli.ts verify",
    "pm2:start": "pm2 start dist/index.js --name openclaw-bridge",
    "pm2:stop": "pm2 stop openclaw-bridge",
    "pm2:restart": "pm2 restart openclaw-bridge"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "pino": "^8.18.0",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
